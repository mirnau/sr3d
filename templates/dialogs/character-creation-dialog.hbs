<form>
  <h2>Assign Priorities</h2>

  <!-- Race Priority -->
  <div class="form-group">
    <label for="race-priority">Race Priority</label>
    <select name="race" class="priority-select">
      <option value="A">A</option>
      <option value="B">B</option>
      <option value="C">C</option>
      <option value="D">D</option>
      <option value="E">E</option>
    </select>
  </div>

  <!-- Magic Priority -->
  <div class="form-group">
    <label for="magic-priority">Magic Priority</label>
    <select name="magic" class="priority-select">
      <option value="A">A</option>
      <option value="B">B</option>
      <option value="C">C</option>
      <option value="D">D</option>
      <option value="E">E</option>
    </select>
  </div>

  <!-- Attributes Priority -->
  <div class="form-group">
    <label for="attributes-priority">Attributes Priority</label>
    <select name="attributes" class="priority-select">
      <option value="A">A</option>
      <option value="B">B</option>
      <option value="C">C</option>
      <option value="D">D</option>
      <option value="E">E</option>
    </select>
  </div>

  <!-- Skills Priority -->
  <div class="form-group">
    <label for="skills-priority">Skills Priority</label>
    <select name="skills" class="priority-select">
      <option value="A">A</option>
      <option value="B">B</option>
      <option value="C">C</option>
      <option value="D">D</option>
      <option value="E">E</option>
    </select>
  </div>

  <!-- Resources Priority -->
  <div class="form-group">
    <label for="resources-priority">Resources Priority</label>
    <select name="resources" class="priority-select">
      <option value="A">A</option>
      <option value="B">B</option>
      <option value="C">C</option>
      <option value="D">D</option>
      <option value="E">E</option>
    </select>
  </div>

  <p><strong>Note:</strong> Each priority can only be used once.</p>
</form>
